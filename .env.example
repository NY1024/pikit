# pikit — environment configuration template.
#
# Copy this file to `.env` and fill in your real values:
#     cp .env.example .env
# Then load it into your shell before running live demos:
#     set -a; source .env; set +a
#
# NEVER commit `.env` (it holds your secret key) — it is gitignored.
# NEVER paste your key directly on the command line: it leaks into shell
# history and logs. Keep it in `.env` and `source` it instead.

# Your API key for an OpenAI-compatible endpoint (required for live demos).
OPENAI_API_KEY=sk-your-key-here

# The API base URL. Omit / leave blank to use the official OpenAI API.
# Example — Alibaba Cloud DashScope (Qwen), OpenAI-compatible mode:
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# The model id to test against (optional; scripts have a default).
PIKIT_MODEL=qwen3.6-flash-2026-04-16
